#!/usr/bin/env bash
set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo is not on PATH. Install Rust or source \"\$HOME/.cargo/env\"." >&2
  exit 1
fi

. scripts/git-hooks/python-env.sh
select_repo_python

echo "pre-push: full local verification chain"
cargo fmt --check \
  && cargo clippy --all-targets --all-features -- -D warnings \
  && cargo test \
  && cargo run -- verify --all \
  && cargo run -- validate --all \
  && PYTHONPATH="${REPO_PYTHONPATH}" "${REPO_PYTHON}" -m unittest discover -s tests -p 'test_*.py' \
  && PYTHONPATH="${REPO_PYTHONPATH}" "${REPO_PYTHON}" scripts/check_repo_consistency.py
